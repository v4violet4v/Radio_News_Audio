# ---------------------------------------------------------------------------
# Audio worker environment (Radio_News_Audio)
#
# Copy to .env for local runs. In GitHub Actions these are provided as
# encrypted Secrets / Variables (see README "Setup"). NEVER commit a real .env.
# Use the SCOPED credentials described in the README, not your admin keys.
# ---------------------------------------------------------------------------

# Shared Neon Postgres (use the scoped `audio_worker` role — SELECT/UPDATE on
# segments + SELECT on categories only). Point at the POOLED connection string.
DATABASE_URL=postgresql://audio_worker:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Cloudflare R2 (use an API token scoped to the audio bucket, Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=news-radio-audio
# Public base URL of the bucket (no trailing slash), e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# TTS (Kokoro). PYTHON_BIN is the interpreter that has the audio deps installed.
TTS_PROVIDER=kokoro
PYTHON_BIN=python
# Pause between sentences in seconds (cadence tuning; default 0.28).
TTS_SENTENCE_GAP_SEC=0.28
# Kokoro model repo (rarely changed).
KOKORO_REPO_ID=hexgrad/Kokoro-82M

# Max segments synthesized per run (Kokoro is slow; leftovers picked up next run).
MAX_AUDIO_PER_RUN=20
